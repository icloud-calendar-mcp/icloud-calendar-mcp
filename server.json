{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "org.onekash/icloud-calendar-mcp",
  "description": "MCP server for iCloud (Apple) Calendar access via CalDAV",
  "repository": {
    "url": "https://github.com/icloud-calendar-mcp/icloud-calendar-mcp",
    "source": "github"
  },
  "version": "3.0.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@icloud-calendar-mcp/server",
      "version": "3.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your Apple ID email (e.g., user@icloud.com)",
          "isRequired": true,
          "format": "string",
          "isSecret": false,
          "name": "ICLOUD_USERNAME"
        },
        {
          "description": "App-specific password for iCloud (not your main Apple ID password)",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "ICLOUD_PASSWORD"
        }
      ]
    }
  ]
}
